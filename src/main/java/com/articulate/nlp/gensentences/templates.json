/*
  templates.json — Templates for synthetic English/logic sentence generation.
  Processed by GenFromTemplate.java.

  ─────────────────────────────────────────────────────────────────────────────
  TOP-LEVEL SETTINGS
  ─────────────────────────────────────────────────────────────────────────────
    resources.morpho_db.path  — path to the MorphoDB snapshot directory; leading ~ is
                        expanded to the user home directory.
                        Overridden by the third CLI argument if supplied.
    resources.morpho_db.query_missing_words — if true, words not found in the DB are
                        queried via LLM, then persisted back into the DB files.
                        Default: false.
    resources.morpho_db.model — LLM model name to use for missing-word queries
                        (passed to GenUtils.setLLMModel).

  ─────────────────────────────────────────────────────────────────────────────
  GLOBAL DEFAULTS  (default_settings)
  ─────────────────────────────────────────────────────────────────────────────
  All fields in default_settings can be overridden per template.

    modal.on          — enable modal wrapping (true/false)
    modal.freq        — probability [0,1] that a sentence gets a modal prefix
    modal.neg_freq    — probability [0,1] that a modal is negated in logic
    modal.values      — list of {sumo_term, text, weight} modal choices
    tense.on          — enable tense variants (true/false)
    tense.none/past/present/future — relative sampling weights for each tense;
                        "none" means tense is not encoded in logic and the default
                        tense is used in the English surface form
    count_prob_dropoff — geometric decay p for collection size sampling (P(k) = (1-p)^(k-2)*p)
    named_human_freq  — probability [0,1] that a Human-typed instance slot renders as a named
                        individual (e.g. "Mary") rather than a generic term; can be overridden
                        per slot with "named_human_freq"; default 0.0 (disabled)
    num_to_gen        — default number of sentences to generate per template
    question_freq     — probability [0,1] that a sentence is rendered as a question

  ─────────────────────────────────────────────────────────────────────────────
  SLOT NOTATION  (in frame strings and logic clauses)
  ─────────────────────────────────────────────────────────────────────────────
    %<n>              — English surface value for slot n (e.g. "a chair", "adjacent to")
    %v<n>             — Conjugated verb phrase for verb slot n (e.g. "is", "was not")
    %?<n>             — KIF variable or named constant for slot n (e.g. "?A1", "ChairInstance")
    %n{...}           — Negation marker: content included only when the verb is negated
    %t{...}           — Tense marker: content wrapped in holdsDuring/before/etc. when tense != NONE

  ─────────────────────────────────────────────────────────────────────────────
  SLOT TYPES  (%<n> slot definitions)
  ─────────────────────────────────────────────────────────────────────────────
    type: "subclass"    — samples a random subclass of the given SUMO term
    type: "instance"    — samples a random instance of the given SUMO term;
                          tracks a KIF variable or named constant (%?<n>)
    type: "positional"  — samples a SUMO PositionalAttribute instance;
                          automatically appends the dependent preposition
                          (e.g. "adjacent" → "adjacent to", "on" → "on")
                          No countable, variable, or definite_freq needed.

  SLOT OPTIONS  (for "subclass" and "instance" types)
    sumo_terms        — weighted list of {name, weight} SUMO classes to draw from
    variable          — optional fixed KIF variable name (e.g. "?A1");
                        also triggers article generation for the English value
    definite_freq     — probability [0,1] of using "the" vs. indefinite article;
                        0.0 = always indefinite, 1.0 = always definite
    countable.possible  — whether collection/list mode is possible (true/false)
    countable.freq      — probability [0,1] of generating a countable (collection or list) when possible
    countable.count_prob_dropoff — geometric decay p for collection member count (higher p → smaller count)
    countable.list_freq — probability [0,1] that a countable becomes a natural-language list
                          instead of a SUMO Collection; evaluated only when freq fires; default 0.0
                          (disabled). Each list item is a fully individual entity with its own
                          instance statement. List items may independently be singletons,
                          named humans, social roles, definite/indefinite, or even SUMO Collections.
                          Template clauses referencing the slot are duplicated once per list item.
    countable.list_prob_dropoff — geometric decay p for list size sampling (min 2);
                          higher p → shorter lists; default equals count_prob_dropoff
    named_human_freq  — per-slot override of the global named_human_freq
    exclude           — optional list of SUMO term names to remove from the candidate pool
                        for this slot (e.g. ["Vertical","Horizontal"]); a warning is printed
                        if an excluded term is not found among the candidates

  ─────────────────────────────────────────────────────────────────────────────
  VERB SLOT OPTIONS  (%v<n> slot definitions)
  ─────────────────────────────────────────────────────────────────────────────
    verbs             — weighted list of {lemma, weight} verb lemmas
    negation          — "on" or "off" to enable verb negation
    neg_freq          — probability [0,1] that the verb is negated

  ─────────────────────────────────────────────────────────────────────────────
  LOGIC CLAUSES
  ─────────────────────────────────────────────────────────────────────────────
  The logic section contains a list of KIF clauses that are assembled into a
  (exists (...) (and ...)) expression.  Clauses of the form (instance %?<n> %<n>)
  are handled specially: for collection slots they expand into three clauses
  (instance ... Collection), (memberType ...), (memberCount ...); for list slots
  they are duplicated once per list item. Definite slots emit their instance
  assertion outside any modal wrapper.
*/
{
  "resources": {
    "morpho_db": {
      "path": "~/.sigmanlp/MorphoDB/gpt-oss_20b",
      "query_missing_words": true,
      "model": "gpt-oss:20b"
    }
  },
  "default_settings":{
      "modal":{
        "on":true,
        "freq":0.1,
        "neg_freq":0.2,
        "values":[
          {"sumo_term":"Necessity",   "text":"it is %n{not} necessary that ",   "weight":1},
          {"sumo_term":"Possibility", "text":"it is %n{not} possible that ",    "weight":1},
          {"sumo_term":"Obligation",  "text":"it is %n{not} obligatory that ",  "weight":1},
          {"sumo_term":"Permission",  "text":"it is %n{not} permitted that ",   "weight":1},
          {"sumo_term":"Prohibition", "text":"it is %n{not} prohibited that ",  "weight":1},
          {"sumo_term":"Likely",      "text":"it is %n{not} likely that ",      "weight":1},
          {"sumo_term":"Unlikely",    "text":"it is %n{not} unlikely that ",    "weight":1}
        ]
      },
      "tense":{
        "on":true,
        "none":10,
        "past":1,
        "present":1,
        "future":1
      },
      "count_prob_dropoff":0.5,
      "named_human_freq":0.5,
      "num_to_gen":100,
      "question_freq":0.1
  },
  "templates":[
    {
      "name":"Orientation",
      "num_to_gen":0,
      "english":{
        "example":"The book is on the table.",
        "frame":{
            "tense_none":["%1 %v1 %2 %3.",
                          "%1 %v1 situated %2 %3.",
                          "%1 %v1 located %2 %3."]
        },
        "frame_question":{
            "tense_none":["%v1 %1 %2 %3?"],
            "tense_future":["Will %1 %v1 %2 %3?"]
        },
        "%1":{
            "variable":"?A1",
            "definite_freq":0.5,
            "sumo_terms":[{"name":"Artifact","weight":5},
                          {"name":"AnatomicalStructure","weight":5},
                          {"name":"Human","weight":100},
                          {"name":"SocialRole","weight":5},
                          {"name":"Animal","weight":5}],
            "type":"subclass",
            "countable":{
                "possible":true,
                "freq":0.5,
                "count_prob_dropoff":0.5,
                "list_freq":0.27,
                "list_prob_dropoff":0.5
            }
        },
        "%2":{
            "sumo_terms":[{"name":"PositionalAttribute","weight":1}],
            "type":"positional",
            "exclude":["Vertical","Horizontal"]
        },
        "%3":{
            "variable":"?O2",
            "definite_freq":0.5,
            "sumo_terms":[{"name":"Object","weight":1}],
            "type":"subclass",
            "countable":{"possible":true, "freq":0.5}
        },
        "%v1":{
            "negation":"on",
            "neg_freq":0.5,
            "verbs":[{"lemma":"be","weight":1}]
        },
        "logic":{
            "clauses":[
                "(instance %?1 %1)",
                "(instance %?3 %3)",
                "%t{%n{(not }(orientation %?1 %?3 %2)%n{)}}"
            ]
        }
      }
    },
    {
      "name":"MovingTowardsFromDirection",
      "num_to_gen":100,
      "english":{
        "example":"The cat is moving towards the house from the north.",
        "frame":{
            "tense_none":["%1 %v1 %2 from %3."],
            "tense_present":["%1 %v1 %2 from %3."],
            "tense_past":["%1 %v1 %2 from %3."],
            "tense_future":["%1 will %v1 %2 from %3."]
        },
        "frame_question":{
            "tense_none":["%1 %v1 %2 %3?"],
            "tense_future":["Will %1 %v1 %2 %3?"]
        },
        "%1":{
            "variable":"?A",
            "definite_freq":0.0,
            "sumo_terms":[{"name":"Animal","weight":10},
                          {"name":"Human","weight":100},
                          {"name":"SocialRole","weight":5}],
            "type":"subclass",
            "countable":{
                "possible":true,
                "freq":0.1,
                "named_human_freq":1.0
            }
        },
        "%2":{
            "variable":"?O",
            "definite_freq":0.0,
            "sumo_terms":[{"name":"Object","weight":1}],
            "type":"subclass",
            "countable":{"possible":true, "freq":0.1},
            "exclude":["AnatomicalStructure"]
        },
        "%3":{
            "variable":"?D",
            "definite_freq":0.0,
            "sumo_terms":[{"name":"PositionalAttribute","weight":1}],
            "type":"positional",
            "include_prep":false
        },
        "%v1":{
            "negation":"off",
            "definite_freq":0.0,
            "neg_freq":0.0,
            "verbs":[{"lemma":"move towards","weight":1},
                     {"lemma":"approach","weight":1},
                     {"lemma":"head towards","weight":1},
                     {"lemma":"advance towards","weight":1},
                     {"lemma":"proceed towards","weight":1},
                     {"lemma":"go towards","weight":1},
                     {"lemma":"come towards","weight":1},
                     {"lemma":"move in the direction of","weight":1},
                     {"lemma":"move closer to","weight":1},
                     {"lemma":"draw near","weight":1}]
      },
      "logic":{
        "clauses":[
            "(instance %?1 %1)",
            "(instance %?2 %2)",
            "(instance %?v1 MovingTowards)",
            "%t{%n{(not }(agent %?v1 %?1) (direction %?v1 %?2) (orientation %?1 %?2 %3)%n{)}}"
        ]
      }
    }
  }
  ]
}
